# PostHog (optional). Copy to .env — never commit .env
# Project API key from https://us.posthog.com/project/settings
VITE_POSTHOG_KEY=
# US cloud default; use https://eu.i.posthog.com for EU
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Supabase Auth (optional). When both are set, Load / Import / drag-drop require a signed-in user.
# URL: Project Settings → API → Project URL (e.g. https://xxxx.supabase.co)
VITE_SUPABASE_URL=https://eqmikgxhrwwnrzcdwcfq.supabase.co
# anon public key: Project Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=
# Google OAuth: Supabase → Authentication → Providers → Google (Client ID + Secret from Google Cloud).
# In Google Cloud Console → Credentials → OAuth client: Authorized redirect URI must include
#   https://eqmikgxhrwwnrzcdwcfq.supabase.co/auth/v1/callback
# Supabase → URL configuration: add Site URL and Redirect URLs (production + http://localhost:5173 for dev).
